{
  "name": "codeigniter/framework",
  "description": "The CodeIgniter framework v4",
  "license": "MIT",
  "type": "library",
  "homepage": "https://codeigniterfuels.com",
  "require": {
    "php": "^7.4 || ^8.0",
    "codeigniter4/framework": "^4.4",
    "codeigniter4/codeigniter4": "^4.4"
  },
  "require-dev": {
    "mikey179/vfsstream": "^1.6",
    "phpunit/phpunit": "^9.5",
    "mockery/mockery": "^1.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "app/Config/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php spark serve",
    "test": "phpunit",
    "migrate": "php spark migrate"
  }
}
